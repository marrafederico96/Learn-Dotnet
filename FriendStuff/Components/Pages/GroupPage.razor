@page "/account/group/{GroupName}"

@using FriendStuff.Components.Shared
@using FriendStuff.Dto
@using Microsoft.AspNetCore.Authorization;

@attribute [Authorize]

<GroupPageComponent GroupName="@GroupName" UserGroups="@UserGroups" UserInfo="@UserInfo" />

@code {
    [Parameter]
    public string? GroupName { get; set; }

    [CascadingParameter(Name = "UserGroups")]
    public List<GroupMemberDto>? UserGroups { get; set; }

    [CascadingParameter(Name = "UserInfo")]
    public UserInfoDto? UserInfo { get; set; }
}