@page "/"

@using FriendStuff.Components.Shared
@using Microsoft.AspNetCore.Authorization;
@using FriendStuff.Dto;

@attribute [Authorize]

<GroupComponent UserInfo="UserInfo" UserGroups="UserGroups" />
<EventComponent />
@code {
    [CascadingParameter(Name = "UserInfo")]
    public UserInfoDto? UserInfo { get; set; }

    [CascadingParameter(Name = "UserGroups")]
    public List<GroupMemberDto>? UserGroups { get; set; }

}